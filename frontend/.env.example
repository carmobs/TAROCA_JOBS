# Environment variables
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_NOMBRE_APP=Taroca Jobs
REACT_APP_VERSION=1.0.0

# Google OAuth
# Obtener de: https://console.cloud.google.com/
# 1. Crear proyecto "TAROCA_JOBS"
# 2. Crear OAuth 2.0 Client ID (Web application)
# 3. Agregar http://localhost:3000 a URIs autorizadas
# 4. Copiar Client ID aquí
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id-here
