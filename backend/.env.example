# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Symmetric Encryption Key (REQUIRED for data encryption)
# Genera una clave aleatoria de al menos 32 caracteres
# Comando: openssl rand -hex 32
# O: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your-encryption-key-here-minimum-32-characters-change-in-production

# Database PostgreSQL
DB_NAME=trabajadores_db
DB_USER=postgres
DB_PASSWORD=your-postgres-password-here
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OAuth2 Google Configuration
# IMPORTANTE: Obtener Client ID de Google Cloud Console
# 1. Ir a https://console.cloud.google.com/
# 2. Crear proyecto "TAROCA_JOBS"
# 3. Habilitar Google+ API
# 4. Crear OAuth 2.0 Client ID (Web application)
# 5. Agregar URIs autorizadas:
#    - http://localhost:3000/auth/callback
#    - http://localhost:8000/accounts/google/login/callback/
# 6. Copiar Client ID aquí
GOOGLE_CLIENT_ID=your-google-client-id-here

# Django-allauth Email Verification
# Valores: optional, mandatory, none
ACCOUNT_EMAIL_VERIFICATION=optional

# Application Settings
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
